{
  "branches": ["master"],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "scripts/build-release.sh ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "dist/BitTime-*.dmg",
            "label": "BitTime installer"
          },
          {
            "path": "dist/BitTime-*.dmg.sha256",
            "label": "Installer SHA-256 checksum"
          },
          {
            "path": "dist/BitTime-*.zip",
            "label": "BitTime.app"
          },
          {
            "path": "dist/BitTime-*.zip.sha256",
            "label": "Zip SHA-256 checksum"
          }
        ]
      }
    ]
  ]
}
